# ============================================================
# DWBS — Rammis Bank Environment Configuration Template
# Copy this file to .env and fill in real values before running.
# NEVER commit the actual .env file to version control.
# ============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# ── JWT Secrets ───────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_64_char_random_hex_string
JWT_REFRESH_SECRET=replace_with_another_64_char_random_hex_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
ANON_SESSION_EXPIRY_MINUTES=30

# ── MySQL Database ────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=rammis_dwbs_db
DB_USER=root
DB_PASSWORD=""
DB_POOL_LIMIT=10

# Separate restricted user for AuditLogs (INSERT-only privilege)
DB_AUDIT_USER=dwbs_audit_user
DB_AUDIT_PASSWORD=replace_with_audit_user_strong_password

# ── File Encryption ────────────────────────────────────────────
# Must be exactly 64 hex characters (32 bytes → AES-256)
FILE_ENC_KEY=replace_with_64_hex_char_aes_key_for_file_encryption_at_rest
FILE_ENC_IV_LENGTH=16
UPLOAD_DIR=./uploads

# ── Microsoft Active Directory / LDAP ─────────────────────────
AD_URL=ldaps://ad.rammisbank.et:636
AD_BASE_DN=DC=rammisbank,DC=et
AD_BIND_DN=CN=dwbs_service,OU=ServiceAccounts,DC=rammisbank,DC=et
AD_BIND_PASSWORD=replace_with_ad_service_account_password
AD_USER_SEARCH_BASE=OU=Staff,DC=rammisbank,DC=et
AD_TLS_CA_CERT_PATH=./certs/rammis-ad-ca.crt

# ── SMTP Email (Gmail) ───────────────────────────────────────
# Uses Gmail SMTP with an App Password (not your Google account password).
# Setup steps:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Search "App Passwords" → generate one for "Mail"
#   4. Paste the 16-character app password below
GMAIL_USER=mujuhusu@gmail.com
GMAIL_APP_PASSWORD=replace_with_16_char_gmail_app_password

# EAAC (Ethics & Anti-Corruption Office) fixed notification email
# New case submissions always trigger an email to this address
EAAC_EMAIL=mujuhusu@gmail.com

# ── Local SMS Gateway (UCS2 / Amharic) ───────────────────────
SMS_GATEWAY_URL=http://sms-gateway.rammisbank.internal/api/send
SMS_GATEWAY_API_KEY=replace_with_sms_gateway_api_key
SMS_SENDER_ID=RammisBank
SMS_DATA_CODING=0x08

# ── hCaptcha ──────────────────────────────────────────────────
HCAPTCHA_SECRET=replace_with_hcaptcha_secret_key
HCAPTCHA_VERIFY_URL=https://hcaptcha.com/siteverify

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
STRICT_RATE_LIMIT_MAX=10
DISABLE_RATE_LIMIT=false

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
LOG_MASK_FIELDS=email,username,description,body,reference_id
