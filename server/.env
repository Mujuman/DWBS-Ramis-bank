# ============================================================
# DWBS Server — Local Development Environment
# DO NOT commit this file to version control.
# ============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# ── JWT Secrets ───────────────────────────────────────────────
JWT_ACCESS_SECRET=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2
JWT_REFRESH_SECRET=b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
ANON_SESSION_EXPIRY_MINUTES=30

# ── MySQL Database ────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=rammis_dwbs_db
DB_USER=root
DB_PASSWORD=
DB_POOL_LIMIT=10

# Audit user (INSERT-only on auditlogs) — set after running schema.sql
DB_AUDIT_USER=root
DB_AUDIT_PASSWORD=

# ── File Encryption ───────────────────────────────────────────
FILE_ENC_KEY=c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4
FILE_ENC_IV_LENGTH=16
UPLOAD_DIR=./uploads

# ── Active Directory / LDAP ───────────────────────────────────
# Leave these as placeholders for now — local sysadmin login bypasses LDAP
AD_URL=ldaps://ad.rammisbank.et:636
AD_BASE_DN=DC=rammisbank,DC=et
AD_BIND_DN=CN=dwbs_service,OU=ServiceAccounts,DC=rammisbank,DC=et
AD_BIND_PASSWORD=replace_with_ad_service_account_password
AD_USER_SEARCH_BASE=OU=Staff,DC=rammisbank,DC=et
AD_TLS_CA_CERT_PATH=./certs/rammis-ad-ca.crt

# ── SMTP ──────────────────────────────────────────────────────
BANK_SMTP_HOST=smtp.rammisbank.et
BANK_SMTP_PORT=587
BANK_SMTP_USER=noreply@rammisbank.et
BANK_SMTP_PASSWORD=replace_with_smtp_password
BANK_SMTP_FROM="Rammis Bank DWBS <noreply@rammisbank.et>"

# ── SMS Gateway ───────────────────────────────────────────────
SMS_GATEWAY_URL=http://sms-gateway.rammisbank.internal/api/send
SMS_GATEWAY_API_KEY=replace_with_sms_gateway_api_key
SMS_SENDER_ID=RammisBank
SMS_DATA_CODING=0x08

# ── hCaptcha ──────────────────────────────────────────────────
# Development: using hCaptcha's official test keys (always pass)
# Production: replace both with your real keys from hcaptcha.com
HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000
HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000000
HCAPTCHA_VERIFY_URL=https://hcaptcha.com/siteverify

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
STRICT_RATE_LIMIT_MAX=10

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
LOG_MASK_FIELDS=email,username,description,body,reference_id
